# Mochi Configuration
# Copy this file to .env and adjust values as needed

# Backend connection (set to empty or remove to use mock mode)
MOCHI_BACKEND_URL=http://127.0.0.1:8000
MOCHI_WS_URL=ws://127.0.0.1:8000/ws/telemetry

# Local LLM settings
OLLAMA_HOST=http://127.0.0.1:11434
MOCHI_MODEL=gemma3:1b
# Alternative models: gemma3:270m (low RAM), llama3.2:1b

# Mock mode (set to 1 to use mock backend without real API)
MOCHI_USE_MOCKS=1

# Dashboard
MOCHI_DASHBOARD_URL=http://127.0.0.1:8501

# Device name (shown in header)
MOCHI_DEVICE_NAME=edge-01

# Polling interval in seconds
MOCHI_POLL_INTERVAL=2.0

# Log level
MOCHI_LOG_LEVEL=INFO
