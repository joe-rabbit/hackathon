/* Mochi TUI - Claude Code Style */
/* Color Palette:
   BACKGROUND = #111111
   SURFACE = #181818
   SURFACE2 = #1e1e1e
   BORDER = #2a2a2a
   TEXT_MAIN = #F5F5F5
   TEXT_DIM = #A8A8A8
   TEXT_DIMMER = #555555
   GREEN = #7EE787
   PINK = #F4A9C4
   HOT = #FF7B8A
   MINT = #C8F0D0
   YELLOW = #FFE066
*/

Screen {
    background: #111111;
}

#main-container {
    width: 100%;
    height: 100%;
    background: #111111;
}

/* Status line at top */
StatusLine {
    height: 1;
    background: #1e1e1e;
    padding: 0 1;
    dock: top;
}

/* Mochi hero scene */
MochiHeroWidget {
    height: 14;
    background: #111111;
    min-height: 12;
}

/* Welcome block */
WelcomeBlock {
    height: auto;
    padding: 1 0;
    text-align: center;
    background: #111111;
}

/* Dot divider */
DotDivider {
    height: 1;
    padding: 0 1;
    text-align: center;
    background: #111111;
}

/* Transcript area */
TranscriptView {
    height: 1fr;
    min-height: 8;
    padding: 1 2;
    background: #111111;
    scrollbar-size: 1 1;
    scrollbar-color: #2a2a2a;
}

TranscriptEntryWidget {
    height: auto;
    margin: 0 0 1 0;
}

/* Prompt input */
PromptInput {
    height: 3;
    background: #181818;
    border-top: solid #2a2a2a;
    padding: 0 1;
}

#prompt-container {
    layout: horizontal;
    height: 1;
    margin-top: 1;
    width: 100%;
}

#prompt-symbol {
    width: 2;
    color: #7EE787;
    text-style: bold;
}

#prompt-input {
    background: transparent;
    border: none;
    color: #F5F5F5;
    width: 1fr;
}

#prompt-input:focus {
    border: none;
}

#prompt-input > .input--placeholder {
    color: #555555;
}

/* Keyboard hints bar */
KbdHintsBar {
    height: 1;
    background: #1e1e1e;
    padding: 0 1;
    dock: bottom;
}
